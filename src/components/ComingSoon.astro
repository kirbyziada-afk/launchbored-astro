---
// ComingSoon.astro
interface ComingSoonProduct {
    name: string;
    description: string;
    image?: string | null;
    link?: string | null;
}
interface Props {
  title: string;
  subtitle: string;
  products: ComingSoonProduct[];
}
const { title, subtitle, products } = Astro.props;
---
<section class="coming-soon stack-section" id="coming-soon">
    <div class="stack-inner bg-dark">
        <div class="container content-wrapper">
            <div class="section-header reveal">
                <h2 class="section-title text-rainbow" set:html={title}></h2>
                <p class="section-desc text-white" set:html={subtitle}></p>
            </div>
            <div class="product-grid reveal">
                {products.map(product => {
                    const CardElement = product.link ? 'a' : 'div';
                    return (
                    <CardElement href={product.link || undefined} target={product.link ? "_blank" : undefined} class="product-card coming-soon-card" style={product.link ? 'text-decoration: none; color: inherit; display: block; cursor: pointer;' : 'display: block;'}>
                        <div class="product-img-placeholder" style="background: #222; position: relative; overflow: hidden;">
                            {product.image && (
                                <img src={product.image} alt={product.name} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;" />
                            )}
                        </div>
                        <div class="product-info" style="background: #1a1a1a; color: #fff;">
                            <h3>{product.name}</h3>
                            <p style="color: #aaa;">{product.description}</p>
                        </div>
                    </CardElement>
                )})}
            </div>
        </div>
    </div>
</section>
