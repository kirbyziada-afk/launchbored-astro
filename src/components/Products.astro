---
// Products.astro
interface Product {
    name: string;
    description: string;
    status: string;
    bgColor: string;
    textColor: string;
    image?: string | null;
    link?: string | null;
}
interface Props {
  title: string;
  subtitle: string;
  products: Product[];
}
const { title, subtitle, products } = Astro.props;
---
<section class="products stack-section" id="products">
    <div class="stack-inner bg-main">
        <div class="container content-wrapper">
            <div class="section-header reveal">
                <h2 class="section-title text-main">{title}</h2>
                <p class="section-desc mb-5" style="color: #444;">{subtitle}</p>
            </div>
            <div class="product-grid reveal">
                {products.map(product => {
                    const CardElement = product.link ? 'a' : 'div';
                    return (
                    <CardElement href={product.link || undefined} target={product.link ? "_blank" : undefined} class="product-card shadow-sm" style={product.link ? 'text-decoration: none; color: inherit; display: block; cursor: pointer;' : 'display: block;'}>
                        <div class="product-img-placeholder" style={`background: ${product.bgColor}; position: relative; overflow: hidden;`}>
                            {product.image && (
                                <img src={product.image} alt={product.name} style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;" />
                            )}
                            <span class="badge" style={`position: relative; z-index: 2; color: ${product.textColor}; ${product.image ? 'background: rgba(255,255,255,0.95); box-shadow: 0 4px 10px rgba(0,0,0,0.1); font-weight: bold;' : ''}`}>{product.status}</span>
                        </div>
                        <div class="product-info bg-main">
                            <h3 class="text-main">{product.name}</h3>
                            <p class="text-muted">{product.description}</p>
                        </div>
                    </CardElement>
                )})}
            </div>
        </div>
    </div>
</section>
